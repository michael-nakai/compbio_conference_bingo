a <- c("shinyjs", "stringr", "dplyr", "bslib", "shiny", 'heatmaply', 'magrittr',
       'reshape2', 'ggplot2', 'ggrepel', 'shinyjqui', 'plotly', 'DT', 'later')

my_packages = a
install_if_missing = function(p) {
    if (p %in% rownames(installed.packages()) == FALSE) {
        install.packages(p)
    }
}
invisible(sapply(my_packages, install_if_missing))
